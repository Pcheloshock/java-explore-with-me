    {
      "name": "Public - Комментарии",
      "description": "Публичные эндпоинты для просмотра комментариев",
      "item": [
        {
          "name": "GET /events/{eventId}/comments - Получить комментарии события",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/comments?from=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "comments"],
              "query": [
                {
                  "key": "from",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "GET /events/{eventId}/comments/{commentId} - Получить комментарий по ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('publishedCommentId')) {",
                  "    pm.test('Status code is 200', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "",
                  "    pm.test('Response has correct structure', function () {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response).to.have.property('id');",
                  "        pm.expect(response).to.have.property('text');",
                  "        pm.expect(response).to.have.property('eventId');",
                  "        pm.expect(response).to.have.property('authorId');",
                  "        pm.expect(response).to.have.property('authorName');",
                  "        pm.expect(response).to.have.property('createdOn');",
                  "        pm.expect(response).to.have.property('status');",
                  "    });",
                  "} else {",
                  "    console.log('Skipping test - no published comment');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/comments/{{publishedCommentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "comments", "{{publishedCommentId}}"]
            }
          }
        }
      ]
    },

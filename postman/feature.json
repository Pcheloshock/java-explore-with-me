        {
          "name": "Создать событие",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.environment.set('eventId', response.id);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const eventDate = new Date();",
                  "eventDate.setDate(eventDate.getDate() + 1);",
                  "const formatted = eventDate.toISOString().replace('T', ' ').substring(0, 19);",
                  "pm.environment.set('eventDate', formatted);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"annotation\": \"Test event annotation for comments testing\",\n    \"category\": {{categoryId}},\n    \"description\": \"This is a test event description for testing comments functionality\",\n    \"eventDate\": \"{{eventDate}}\",\n    \"location\": {\n        \"lat\": 55.7558,\n        \"lon\": 37.6176\n    },\n    \"paid\": false,\n    \"participantLimit\": 10,\n    \"requestModeration\": true,\n    \"title\": \"Test Event for Comments {{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{initiatorId}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{initiatorId}}", "events"]
            }
          }
        },
        {
          "name": "Опубликовать событие (админ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [

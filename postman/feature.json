              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{participantId}}/requests?eventId={{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{participantId}}", "requests"],
              "query": [
                {
                  "key": "eventId",
                  "value": "{{eventId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Подтвердить заявку (админ события)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
